# Required
OPENAI_API_KEY=sk-...

# Optional – enables real web search via Tavily (https://tavily.com)
# Without this, DuckDuckGo is used as fallback, then OpenAI knowledge
TAVILY_API_KEY=tvly-...

# Database (auto-set by docker-compose, override for local dev)
DATABASE_URL=postgresql://research_user:research_pass@localhost:5432/research_db

# Model settings (optional)
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
MAX_SEARCH_RESULTS=5
